{
  "name": "kops-filter-exporter",
  "version": "2.1.1",
  "private": true,
  "description": "Browser extension (MV3, Chrome + Firefox) that extracts filters from V-Tools and Souk.to and exports them as a typed JSON envelope for import into Kops.",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "build:firefox": "node build.mjs && node scripts/build-firefox.mjs",
    "lint:firefox": "web-ext lint --source-dir build/firefox",
    "run:firefox": "web-ext run --source-dir build/firefox --target firefox-desktop",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "validate:exports": "node scripts/validate-export.ts",
    "anonymize": "node scripts/anonymize-export.mjs",
    "sync:schema": "node scripts/sync-schema.mjs",
    "verify:schema": "node scripts/sync-schema.mjs --check"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@types/chrome": "^0.0.270",
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "happy-dom": "^20.10.6",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "web-ext": "^10.5.0",
    "zod": "^3.24.0"
  },
  "dependencies": {
    "preact": "^10.29.2"
  }
}
