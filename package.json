{
  "name": "kops-filter-exporter",
  "version": "2.0.0",
  "private": true,
  "description": "Chrome extension (MV3) that extracts filters from V-Tools and Souk.to and exports them as a typed JSON envelope for import into Kops.",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "anonymize": "node scripts/anonymize-export.mjs",
    "sync:schema": "node scripts/sync-schema.mjs",
    "verify:schema": "node scripts/sync-schema.mjs --check"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zod": "^3.24.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
