{
  "manifest_version": 3,
  "name": "Kops Filter Exporter",
  "version": "2.0.0",
  "description": "Extract filters from V-Tools and Souk.to and export them as a typed JSON envelope for import into Kops, the fastest Vinted monitor.",
  "homepage_url": "https://getkops.com",
  "author": "Kops",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "dist/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.v-tools.com/*",
        "*://souk.to/*",
        "*://*.souk.to/*"
      ],
      "js": [
        "dist/inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*.v-tools.com/*"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://souk.to/*",
        "*://*.souk.to/*"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
